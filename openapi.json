oleUpdate":{"properties":{"role":{"allOf":[{"$ref":"#/components/schemas/UserRole"}],"description":"New role to assign"}},"type":"object","required":["role"],"title":"RoleUpdate"},"StatusUpdate":{"properties":{"is_active":{"type":"boolean","title":"Is Active","description":"Set to true to activate, false to deactivate"}},"type":"object","required":["is_active"],"title":"StatusUpdate"},"SummaryResponse":{"properties":{"total_income":{"type":"number","title":"Total Income"},"total_expenses":{"type":"number","title":"Total Expenses"},"net_balance":{"type":"number","title":"Net Balance"},"total_records":{"type":"integer","title":"Total Records"}},"type":"object","required":["total_income","total_expenses","net_balance","total_records"],"title":"SummaryResponse"},"TokenResponse":{"properties":{"access_token":{"type":"string","title":"Access Token"},"token_type":{"type":"string","title":"Token Type","default":"bearer"},"user":{"$ref":"#/components/schemas/UserResponse"}},"type":"object","required":["access_token","user"],"title":"TokenResponse"},"UserCreate":{"properties":{"name":{"type":"string","maxLength":100,"minLength":2,"title":"Name","examples":["Alice Admin"]},"email":{"type":"string","format":"email","title":"Email","examples":["alice@example.com"]},"password":{"type":"string","minLength":6,"title":"Password","examples":["secret123"]},"role":{"anyOf":[{"$ref":"#/components/schemas/UserRole"},{"type":"null"}],"description":"Defaults to 'viewer' if not provided","default":"viewer"}},"type":"object","required":["name","email","password"],"title":"UserCreate"},"UserLogin":{"properties":{"email":{"type":"string","format":"email","title":"Email","examples":["admin@finance.com"]},"password":{"type":"string","title":"Password","examples":["admin123"]}},"type":"object","required":["email","password"],"title":"UserLogin"},"UserResponse":{"properties":{"id":{"type":"integer","title":"Id"},"name":{"type":"string","title":"Name"},"email":{"type":"string","title":"Email"},"rol